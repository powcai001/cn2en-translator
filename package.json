{
  "name": "cn2en-translator",
  "version": "1.0.0",
  "description": "中英文一键翻译桌面工具",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development concurrently \"vite\" \"tsc -w -p tsconfig.electron.json\" \"wait-on http://localhost:5173 && wait-on dist/main.js && electron .\"",
    "electron:build": "npm run build && tsc -p tsconfig.electron.json && electron-builder --publish never"
  },
  "keywords": [
    "electron",
    "translator",
    "chinese",
    "english"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "electron-screenshots": "^0.6.1",
    "electron-store": "^8.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "screenshot-desktop": "^1.15.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.cn2en.translator",
    "productName": "CN2EN Translator",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "src/selection.html",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
